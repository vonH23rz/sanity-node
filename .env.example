# Sanity Node host port
SANITY_NODE_PORT=8099

# Timezone used inside the container
TZ=Europe/Berlin

# Run container processes as this host user/group
# On most Linux systems, 1000:1000 is the first normal user.
PUID=1000
PGID=1000

# Generator refresh interval in seconds
SANITY_NODE_REFRESH_SECONDS=300

# Optional runtime overrides
SANITY_NODE_CONFIG=/app/config/config.yaml
SANITY_NODE_OUTPUT=/app/html/index.html
SANITY_NODE_SSH_USER=truenas_admin
SANITY_NODE_SSH_KEY=/app/ssh/id_ed25519
